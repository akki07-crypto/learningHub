# Django Settings
SECRET_KEY=django-insecure-key-change-this-in-production-12345
DEBUG=True
ALLOWED_HOSTS=127.0.0.1,localhost

# Database Settings (MySQL Configuration)
# Default is SQLite for easy local dev, set USE_MYSQL=True to use MySQL
USE_MYSQL=False
DB_NAME=elearn_db
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_HOST=127.0.0.1
DB_PORT=3306

# API Keys (Optional - System will use Mock Fallback if not provided)
YOUTUBE_API_KEY=your_youtube_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here
FORMSPREE_ENDPOINT_ID=your_formspree_id_here
